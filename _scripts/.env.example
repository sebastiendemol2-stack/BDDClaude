# --- brain.py (mémoire persistante sessions Claude) ---
BRAIN_URL=https://<project-id>.supabase.co
BRAIN_SERVICE_KEY=eyJ...  # service_role key (admin — ne pas commiter)

# --- sync.py (sync vault Obsidian ↔ Supabase) ---
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=eyJ...  # anon key (publique)
# Chemin absolu vers la racine du vault (doit aussi être défini comme variable
# d'environnement système/utilisateur pour que les hooks Claude Code y accèdent)
VAULT_PATH=/chemin/vers/votre/vault

# --- rag_bridge.py (RAG local Jan) ---
JAN_BASE_URL=http://localhost:1337
JAN_EMBED_BASE_URL=http://127.0.0.1:1338
JAN_API_KEY=secret-key-123
JAN_EMBED_API_KEY=secret-key-123
JAN_CHAT_MODEL=gemma-4-E2B-it-IQ4_XS
JAN_EMBED_MODEL=sentence-transformer-mini
RAG_EMBED_TIMEOUT=30
RAG_CHAT_TIMEOUT=180

# --- embed.py (embeddings multi-provider) ---
# Provider principal : Jan AI (localhost:1337, nomic-embed-text)
# Fallback : OpenAI (décommenter la ligne ci-dessous)
# OPENAI_API_KEY=sk-...  # OpenAI API key pour embeddings fallback

# --- ingest.py (pipeline raw → wiki) ---
# (utilise les mêmes SUPABASE_URL / SUPABASE_ANON_KEY que sync.py)

# --- Activation optionnelle ---
# EMBED_ON_PUSH=true   # Générer les embeddings après chaque push sync
