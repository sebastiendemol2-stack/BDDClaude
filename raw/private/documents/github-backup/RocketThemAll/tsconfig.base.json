{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@rta/shared": ["./packages/shared/src"],
      "@rta/database": ["./packages/database/src"],
      "@rta/services": ["./packages/services/src"],
      "@rta/auth": ["./packages/auth/src"],
      "@rta/auth/*": ["./packages/auth/src/*"]
    }
  }
}
