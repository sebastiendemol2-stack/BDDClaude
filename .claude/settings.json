{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,subprocess;p=os.getcwd();os.environ['VAULT_PATH']=p;subprocess.run([sys.executable,os.path.join(p,'_scripts','brain.py'),'load','--dir',p], check=False)\"",
            "description": "Charge le contexte vault avec minimisation de tokens"
          }
        ],
        "matcher": ".*"
      }
    ],
    "Notification": [
      {
        "matcher": ".*9[0-9]%.*",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,subprocess;p=os.getcwd();os.environ['VAULT_PATH']=p;subprocess.run([sys.executable,os.path.join(p,'_scripts','brain.py'),'save','--dir',p,'--mode','autosave'], check=False)\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,subprocess;p=os.getcwd();os.environ['VAULT_PATH']=p;subprocess.run([sys.executable,os.path.join(p,'_scripts','brain.py'),'save','--dir',p,'--mode','close'], check=False)\""
          }
        ]
      }
    ]
  }
}
